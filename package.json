{
  "name": "eudorax-creative-studio",
  "version": "4.8.0-vim-edition",
  "private": true,
  "description": "Gemini-Powered AI Studio running on Node.js 25 runtime.",
  "engines": {
    "node": ">=25.0.0",
    "npm": ">=11.0.0"
  },
  "type": "module",
  "scripts": {
    "dev": "node --experimental-strip-types --experimental-transform-types --watch server.ts",
    "build": "vite build --target=esnext",
    "preview": "vite preview",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "test:node25": "node --test --test-reporter=spec --experimental-vm-modules"
  },
  "dependencies": {
    "@google/genai": "^1.30.0",
    "bcryptjs": "^3.0.3",
    "express": "^5.2.1",
    "framer-motion": "^12.0.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.475.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.173.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.0.0"
  },
  "eudoraConfig": {
    "runtime": "NodeJS25",
    "sharedMemory": "active",
    "tensorBridge": "node:ai",
    "vimMode": "neovim-lua-v5"
  }
}
